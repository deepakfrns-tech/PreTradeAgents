{
  "permissions": {
    "allow": [
      "Bash(mvn test*)",
      "Bash(mvn clean*)",
      "Bash(java -jar*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(ls*)",
      "Bash(mkdir*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
